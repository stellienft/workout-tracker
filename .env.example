# Supabase project settings — Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Never expose to the browser. Used for admin server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Base URL of the deployed app (used in auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Transactional email (Resend — https://resend.com). Optional: if unset, the
# new-member admin notification silently no-ops.
RESEND_API_KEY=your-resend-api-key
# Sender. Default "Stellio Fit <onboarding@resend.dev>" works to the Resend
# account owner immediately; use an address on your verified domain in prod.
EMAIL_FROM=Stellio Fit <noreply@stellio.fit>
# Where new-member notifications are sent (defaults to hello@stellio.com.au)
ADMIN_EMAIL=hello@stellio.com.au
